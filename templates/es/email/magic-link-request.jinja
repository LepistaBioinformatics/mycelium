{% extends "es/email/base.jinja" %}

{% block title %}
Su Enlace de Acceso
{% endblock title %}

{% block head %}
{{ super() }}
{% endblock head %}

{% block contenttitle %}
Su Enlace de Acceso
{% endblock contenttitle %}

{% block contenttable %}
<tbody>
  <tr>
    <td align="left">

      <p>
        Haga clic en el enlace a continuación para iniciar sesión en
        {{ domain_name }}. El enlace mostrará un código de 6 dígitos que deberá
        ingresar en la aplicación. Expira en 15 minutos y solo puede usarse
        una vez.
      </p>

      <table
        style="max-width: 555px; width: 100%; font-family: 'Open Sans', arial, sans-serif; font-size: 13px; color: #323232;"
        cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" align="center">
        <tbody>
          <tr>
            <td height="10">&nbsp;</td>
          </tr>
          <tr>
            <td style="text-align: center">
              <a href="{{ magic_link_url }}"
                style="color: #fff; background-color: hsla(199, 69%, 84%, 1); width: 320px; font-size: 16px; border-radius: 3px; line-height: 44px; height: 44px; font-family: 'Open Sans', Arial, helvetica, sans-serif; text-align: center; text-decoration: none; display: inline-block;">
                <span style="color: #000000">
                  <strong>Abrir Página de Inicio de Sesión</strong>
                </span>
              </a>
            </td>
          </tr>
          <tr>
            <td height="10">&nbsp;</td>
          </tr>
          <tr>
            <td style="text-align: center; font-size: 11px; color: #888888;">
              Si el botón anterior no funciona, copie y pegue esta URL en su
              navegador:<br/>
              {{ magic_link_url }}
            </td>
          </tr>
        </tbody>
      </table>

      <p style="font-size: 11px; color: #888888;">
        Si usted no solicitó este enlace, puede ignorar este correo
        electrónico de forma segura.
      </p>

    </td>
  </tr>
</tbody>
{% endblock contenttable %}
