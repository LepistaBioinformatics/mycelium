{% extends "en-us/email/base.jinja" %}

{% block title %}
Your Login Link
{% endblock title %}

{% block head %}
{{ super() }}
{% endblock head %}

{% block contenttitle %}
Your Login Link
{% endblock contenttitle %}

{% block contenttable %}
<tbody>
  <tr>
    <td align="left">

      <p>
        Click the link below to log in to {{ domain_name }}. The link will show
        you a 6-digit code that you will enter in the app. It expires in
        15 minutes and can only be used once.
      </p>

      <table
        style="max-width: 555px; width: 100%; font-family: 'Open Sans', arial, sans-serif; font-size: 13px; color: #323232;"
        cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" align="center">
        <tbody>
          <tr>
            <td height="10">&nbsp;</td>
          </tr>
          <tr>
            <td style="text-align: center">
              <a href="{{ magic_link_url }}"
                style="color: #fff; background-color: hsla(199, 69%, 84%, 1); width: 320px; font-size: 16px; border-radius: 3px; line-height: 44px; height: 44px; font-family: 'Open Sans', Arial, helvetica, sans-serif; text-align: center; text-decoration: none; display: inline-block;">
                <span style="color: #000000">
                  <strong>Open Login Page</strong>
                </span>
              </a>
            </td>
          </tr>
          <tr>
            <td height="10">&nbsp;</td>
          </tr>
          <tr>
            <td style="text-align: center; font-size: 11px; color: #888888;">
              If the button above does not work, copy and paste this URL into
              your browser:<br/>
              {{ magic_link_url }}
            </td>
          </tr>
        </tbody>
      </table>

      <p style="font-size: 11px; color: #888888;">
        If you did not request this link, you can safely ignore this email.
      </p>

    </td>
  </tr>
</tbody>
{% endblock contenttable %}
