<!DOCTYPE html>
<html lang="en">

<head>
  {% block head %}
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}{% endblock title %} - {{ domain_name }}</title>
  {% endblock head %}
</head>

<body>
  <!-- Brand header -->
  <table
    style="max-width: 555px; width: 100%; font-family: 'Open Sans', Arial, Helvetica, sans-serif; background: #fff; font-size: 13px; color: #323232; border-bottom: 3px solid #bae6fd;"
    cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" align="center">
    <tbody>
      <tr>
        <td style="padding: 20px 24px 16px;">
          <span style="font-size: 20px; font-weight: 700; color: #8b5cf6; letter-spacing: -0.01em;">Mycelium</span>
        </td>
      </tr>
    </tbody>
  </table>

  <div id="content">
    {% block content %}
    <table
      style="max-width: 555px; width: 100%; font-family: 'Open Sans', Arial, Helvetica, sans-serif; background: #fff; font-size: 13px; color: #323232;"
      cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" align="center">

      <tbody>
        <tr>
          <td>
            <h1 style="text-align: center; font-size: 15px;">
              <strong style="font-size: 22px;">
                {% block contenttitle %}{% endblock contenttitle %}
              </strong>
            </h1>
          </td>
        </tr>
      </tbody>

      {% block contenttable %}{% endblock contenttable %}

    </table>
    {% endblock content %}
  </div>

  <div id="footer">
    {% if support_email %}
    <table
      style="max-width: 555px; width: 100%; font-family: 'Open Sans', Arial, Helvetica, sans-serif; font-size: 13px; color: #323232;"
      cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" align="center">
      <tbody>
        <tr>
          <td height="10">&nbsp;</td>
        </tr>
        <tr>
          <td align="left">
            <p>
              If you have any questions, please contact us at
              <a href="mailto:{{ support_email }}">{{ support_email }}</a>.
            </p>
          </td>
        </tr>
      </tbody>
    </table>
    {% endif %}

    {% if domain_url %}
    <table
      style="max-width: 555px; width: 100%; font-family: 'Open Sans', Arial, Helvetica, sans-serif; font-size: 13px; color: #323232;"
      cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" align="center">
      <tbody>
        <tr>
          <td height="10">&nbsp;</td>
        </tr>
        <tr>
          <td align="left">
            <p>
              You can also visit our website at
              <a href="{{ domain_url }}">{{ domain_url }}</a>.
            </p>
          </td>
        </tr>
      </tbody>
    </table>
    {% endif %}

    <table
      style="max-width: 555px; width: 100%; font-family: 'Open Sans', Arial, Helvetica, sans-serif; font-size: 12px; color: #888;"
      cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" align="center">
      <tbody>
        <tr>
          <td height="10">&nbsp;</td>
        </tr>
        <tr>
          <td align="center">
            <p>
              Powered by <a href="https://lepista.com.br" style="color: #8b5cf6; text-decoration: none;">LepistaBioinformatics</a>
            </p>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</body>

</html>
