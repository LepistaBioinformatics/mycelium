"name = \"metrics-push\"\n"
"type = \"python\"\n"
"scriptPath = \"/opt/mycelium/callbacks/push_metrics.py\"\n"
"pythonPath = \"/usr/bin/python3.12\"\n"
"timeoutMs = 5000\n"
"```"
