msgstr "**Mecanismo de autenticação**"

#: src/10-alternative-idps.md:459
msgid "`initData` → connection string (JWT)"
msgstr "`initData` → string de conexão (JWT)"

#: src/10-alternative-idps.md:459
msgid "Webhook secret + sender ID from body"
msgstr "Segredo de webhook + ID do remetente do corpo"

#: src/10-alternative-idps.md:460
msgid "**Tenant Telegram config required**"
msgstr "**Configuração do Telegram no tenant necessária**"

#: src/10-alternative-idps.md:460
msgid "Yes — every tenant used for login"
msgstr "Sim — todo tenant usado para login"

#: src/10-alternative-idps.md:460
msgid "No — global identity lookup"
msgstr "Não — busca global de identidade"

#: src/10-alternative-idps.md:461
msgid "**Gateway route config**"
msgstr "**Configuração de rota do gateway**"

#: src/10-alternative-idps.md:461
msgid "Standard `authenticated`/`protected`"
msgstr "`authenticated`/`protected` padrão"

#: src/10-alternative-idps.md:461
msgid "`allowedSources` + `identitySource = \"telegram\"`"
msgstr ""

#: src/10-alternative-idps.md:462
msgid "**Webhook registration with Telegram**"
msgstr "**Registro de webhook no Telegram**"

#: src/10-alternative-idps.md:462
msgid "Not required"
msgstr "Não obrigatório"

#: src/10-alternative-idps.md:462
msgid "Required (`setWebhook`)"
msgstr "Obrigatório (`setWebhook`)"

#: src/10-alternative-idps.md:463
msgid "**User must have linked identity**"
msgstr "**O usuário deve ter identidade vinculada**"

#: src/10-alternative-idps.md:463
msgid "Yes — via any configured tenant"
msgstr "Sim — via qualquer tenant configurado"

#: src/10-alternative-idps.md:464
msgid "**Connection string issued**"
msgstr "**Connection string emitida**"

#: src/10-alternative-idps.md:464
